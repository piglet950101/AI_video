# ================================================================
# Erro Zero — AI Video Automation
# Copy this to .env.local and fill the values. NEVER commit .env.local
# ================================================================

# ---------- App ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Encryption key for Meta token at-rest. Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY=""

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Magic-link email (uses any SMTP — Gmail, SendGrid, Resend SMTP, etc.)
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="ErroZero <no-reply@errozero.online>"

# Single authorized user email (magic-link gate)
# Only this email can log in. Set to Marcelo's email at handoff.
ALLOWED_LOGIN_EMAIL="marcelo@errozero.online"

# ---------- Supabase (Postgres) ----------
DATABASE_URL=""
DIRECT_URL=""

# ---------- Upstash Redis ----------
REDIS_URL=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---------- Cloudflare R2 ----------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="errozero-media"
R2_PUBLIC_URL=""

# ---------- Sentry ----------
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT="errozero"

# ---------- Better Stack (Logtail) ----------
LOGTAIL_SOURCE_TOKEN=""

# ---------- HeyGen (Yasmin-owned, permanent) ----------
HEYGEN_API_KEY=""
HEYGEN_WEBHOOK_SECRET=""

# ---------- Anthropic (Claude) ----------
ANTHROPIC_API_KEY=""

# ---------- Meta (Instagram + Facebook) ----------
# Filled after Marcelo creates his Meta Developer App on Day 1
META_APP_ID=""
META_APP_SECRET=""
META_OAUTH_REDIRECT_URI="http://localhost:3000/api/meta/oauth/callback"
META_GRAPH_VERSION="v21.0"

# ---------- Cron auth ----------
# Secret shared between Vercel Cron and the endpoint.
# Generate with: openssl rand -hex 32
CRON_SECRET=""
